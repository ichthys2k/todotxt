{
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "verticalContentAlignment": "Center",
          "items": [
            {
              "type": "TextBlock",
              "text": "Todo.txt",
              "weight": "Bolder",
              "size": "Medium",
              "color": "Accent"
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "verticalContentAlignment": "Center",
          "items": [
            {
              "type": "ActionSet",
              "actions": [
                {
                  "type": "Action.Execute",
                  "title": "↻",
                  "verb": "refresh"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "Input.Text",
          "id": "newTaskText",
          "placeholder": "Neue Aufgabe..."
        },
        {
          "type": "ActionSet",
          "actions": [
            {
              "type": "Action.Execute",
              "title": "Aufgabe hinzufügen",
              "verb": "add-task"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Aufgaben:",
      "weight": "Bolder",
      "spacing": "Medium"
    },
    {
      "type": "Container",
      "$data": "${tasks}",
      "separator": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${priorityText}${description}",
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.Execute",
                      "title": "✓",
                      "verb": "complete-task",
                      "data": {
                        "taskId": "${id}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
