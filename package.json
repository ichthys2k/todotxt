{
  "name": "todotxtwebapp",
  "private": true,
  "version": "1.3.2",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "twa:init": "npx @bubblewrap/cli init --manifest=https://deine-domain.de/manifest.webmanifest",
    "twa:build": "npx @bubblewrap/cli build",
    "deploy": "tsc -b && vite build && node deploy.mjs",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-packager . \"Todo.txt\" --platform=win32 --arch=x64 --out=dist-desktop --overwrite",
    "electron:portable": "node package-portable.mjs",
    "electron:exe": "node make-exe.mjs",
    "electron:installer": "node make-installer.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open": "npx cap open",
    "cap:build": "npm run build && npx cap copy && npx cap sync"
  },
  "dependencies": {
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@azure/msal-browser": "^5.11.0",
    "@azure/msal-react": "^5.4.2",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@react-oauth/google": "^0.13.5",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "dotenv": "^17.4.2",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase": "^12.14.0",
    "globals": "^17.6.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-google-drive-picker": "^1.2.2",
    "sharp": "^0.34.5",
    "ssh2-sftp-client": "^12.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.todotxt.webapp",
    "productName": "Todo.txt",
    "publish": {
      "provider": "github",
      "owner": "ichthys2k",
      "repo": "todotxt"
    },
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs",
      "public/icon.png"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "TodoTxt-Windows-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Todo.txt",
      "artifactName": "TodoTxt-Windows-Setup.exe"
    }
  }
}
